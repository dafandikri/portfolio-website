    "@vercel/speed-insights": "^1.2.0",
    "@xmldom/xmldom": "^0.9.8",
    "bootstrap": "^5.3.3",
    "dotenv": "^17.2.1",
    "framer-motion": "^12.5.0",
    "mermaid": "^11.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "terser": "^5.43.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@fullhuman/postcss-purgecss": "^7.0.2",
